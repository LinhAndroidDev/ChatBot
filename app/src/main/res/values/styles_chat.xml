<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearanceOverlay.Chat.Composer" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/chat_composer_corner_top</item>
        <item name="cornerSizeTopRight">@dimen/chat_composer_corner_top</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="TextAppearance.Chat.Role" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Chat.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.18</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Chat.Time" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Chat.Code" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingMultiplier">1.25</item>
        <item name="fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.Chat.CodeLang" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
</resources>
