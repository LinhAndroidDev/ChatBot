<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/chat_markdown_block_spacing_top_code"
    android:layout_marginBottom="@dimen/chat_markdown_block_spacing_bottom"
    app:cardBackgroundColor="@color/chat_markdown_code_block_bg"
    app:cardCornerRadius="@dimen/chat_code_block_card_corner"
    app:cardElevation="0dp"
    app:strokeColor="@color/chat_code_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="2dp"
        android:paddingEnd="4dp"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/chat_markdown_code_copy"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="5dp"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_gravity="end"
            android:contentDescription="@string/chat_copy_code"
            android:src="@drawable/ic_copy_24"
            app:tint="@color/chat_assistant_role" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:isScrollContainer="true"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="none">

            <TextView
                android:id="@+id/chat_markdown_code_text"
                style="@style/TextAppearance.Chat.Code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:lineSpacingMultiplier="1"
                android:paddingHorizontal="8dp"
                android:paddingBottom="4dp"
                android:scrollHorizontally="true"
                android:textColor="@color/chat_markdown_code_text"
                android:textIsSelectable="true"
                tools:text="fun main() { println(42) }" />
        </HorizontalScrollView>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
